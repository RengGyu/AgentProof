{
  "name": "agentproof",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "smoke:analyze-pr": "node scripts/smoke-analyze-pr-url.mjs",
    "smoke:real-prs": "node scripts/smoke-real-pr-evaluation.mjs",
    "smoke:production-regression": "node scripts/smoke-real-pr-evaluation.mjs",
    "smoke:external-pr-pilot": "node scripts/external-pr-pilot-smoke.mjs",
    "smoke:github-comment": "node scripts/smoke-github-comment.mjs",
    "smoke:github-webhook": "node scripts/smoke-github-webhook.mjs",
    "smoke:github-webhook-live": "node scripts/smoke-github-webhook-live.mjs",
    "smoke:openai": "node scripts/smoke-openai-verifier.mjs",
    "ops:drill-gate": "node scripts/ops-drill-gate-readiness.mjs",
    "eval:fetch:swebench": "node scripts/build-eval-pack.mjs",
    "eval:promote:fixture": "node scripts/promote-eval-fixture.mjs",
    "eval:pack": "vitest run src/lib/evaluation-pack.test.ts scripts/build-eval-pack.test.mjs scripts/promote-eval-fixture.test.mjs",
    "eval:sentinels": "vitest run src/lib/reviewer-signal-sentinels.test.ts",
    "eval:summary": "vitest run --config vitest.eval.config.ts --reporter=verbose",
    "eval:summary:strict": "AGENTPROOF_EVAL_STRICT=1 vitest run --config vitest.eval.config.ts --reporter=verbose",
    "eval:summary:fixture": "AGENTPROOF_EVAL_FIXTURE_ONLY=1 vitest run --config vitest.eval.config.ts --reporter=verbose",
    "eval:summary:fixture:strict": "AGENTPROOF_EVAL_FIXTURE_ONLY=1 AGENTPROOF_EVAL_STRICT=1 vitest run --config vitest.eval.config.ts --reporter=verbose"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9"
  }
}
