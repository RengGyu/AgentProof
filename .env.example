# AgentProof runs the deterministic demo/analyze path without env vars.
# Copy this file to .env.local only for local integration testing.

# OpenAI verifier adapter
OPENAI_API_KEY=
AGENTPROOF_LLM_TOKEN=
# Optional. Defaults to gpt-5-mini when omitted.
OPENAI_MODEL=

# Slack notifications are optional and should remain unset until you want live channel posts.
SLACK_WEBHOOK_URL=
AGENTPROOF_NOTIFY_TOKEN=

# GitHub App webhook intake. Automated GitHub App actions are still disabled in code.
GITHUB_APP_ID=
# For local .env.local, escaped newlines are supported:
# GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional smoke-test target. Defaults to the production alias.
AGENTPROOF_BASE_URL=https://agentproof-pearl.vercel.app
