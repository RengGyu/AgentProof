# AgentProof runs the deterministic demo/analyze path without env vars.
# Copy this file to .env.local only for local integration testing.

# OpenAI verifier adapter
OPENAI_API_KEY=
AGENTPROOF_LLM_TOKEN=
# Optional. Defaults to gpt-5-mini when omitted.
OPENAI_MODEL=

# Slack notifications are optional and should remain unset until you want live channel posts.
SLACK_WEBHOOK_URL=
AGENTPROOF_NOTIFY_TOKEN=

# Optional durable summary-only saved reports.
# Leave unset for in-memory demo storage. Never prefix the service-role key with NEXT_PUBLIC_.
AGENTPROOF_REPORTS_SUPABASE_URL=
AGENTPROOF_REPORTS_SUPABASE_SERVICE_ROLE_KEY=
# Optional. Defaults to agentproof_saved_reports.
AGENTPROOF_REPORTS_TABLE=

# GitHub App webhook dry-run intake. Automated GitHub App actions are still disabled in code.
# Signed dry-run intake requires only GITHUB_WEBHOOK_SECRET.
# Future automation will also require GITHUB_APP_ID, GITHUB_PRIVATE_KEY, installation tokens, and idempotency storage.
GITHUB_APP_ID=
# For local .env.local, escaped newlines are supported:
# GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional smoke-test target. Defaults to the production alias.
AGENTPROOF_BASE_URL=https://agentproof-pearl.vercel.app

# Optional live GitHub comment smoke. Keep unset unless you intentionally want to post/update
# an AgentProof marker comment on the target PR.
AGENTPROOF_SMOKE_BASE_URL=https://agentproof-pearl.vercel.app
AGENTPROOF_COMMENT_SMOKE_PR_URL=
AGENTPROOF_COMMENT_SMOKE_GITHUB_TOKEN=
# Optional, only for private PR analysis. Do not reuse broader tokens unless needed.
AGENTPROOF_COMMENT_SMOKE_ANALYZE_TOKEN=
AGENTPROOF_COMMENT_SMOKE_TASK_TEXT=
