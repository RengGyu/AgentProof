# AgentProof runs the deterministic demo/analyze path without env vars.
# Copy this file to .env.local only for local integration testing.

# OpenAI verifier adapter
OPENAI_API_KEY=
AGENTPROOF_LLM_TOKEN=
# Optional. Defaults to gpt-5-mini when omitted.
OPENAI_MODEL=

# Slack notifications are optional and should remain unset until you want live channel posts.
# SLACK_WEBHOOK_URL is also used by the operator-only summary queue alert route.
SLACK_WEBHOOK_URL=
AGENTPROOF_NOTIFY_TOKEN=

# Optional durable summary-only saved reports.
# Leave unset for in-memory demo storage. Never prefix the service-role key with NEXT_PUBLIC_.
AGENTPROOF_REPORTS_SUPABASE_URL=
AGENTPROOF_REPORTS_SUPABASE_SERVICE_ROLE_KEY=
# Optional. Defaults to agentproof_saved_reports.
AGENTPROOF_REPORTS_TABLE=

# GitHub App webhook intake. Default behavior is signed dry-run only.
# Automation requires explicit opt-in plus an allowed repository list.
GITHUB_APP_ID=
# For local .env.local, escaped newlines are supported:
# GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
AGENTPROOF_GITHUB_APP_AUTOMATION_ENABLED=false
AGENTPROOF_GITHUB_APP_ALLOWED_REPOS=
# Optional. Creates summary-only report URLs for webhook-triggered analyses.
AGENTPROOF_GITHUB_APP_SAVE_REPORTS=false
# Optional. Posts/updates one AgentProof GitHub App marker comment. Keep false by default.
AGENTPROOF_GITHUB_APP_COMMENT_ENABLED=false
# Optional. When true, saved report/comment side effects require durable audit storage first.
AGENTPROOF_REQUIRE_DURABLE_AUDIT_FOR_SIDE_EFFECTS=false

# Invite-only GitHub App onboarding and tenant repository grants.
# These are server-only. Never expose service-role keys with NEXT_PUBLIC_.
AGENTPROOF_GITHUB_APP_SLUG=
AGENTPROOF_ONBOARDING_STATE_SECRET=
# Required for HttpOnly tenant admin sessions on /tenant. Use a distinct random secret.
AGENTPROOF_TENANT_SESSION_SECRET=
# Preferred: tenant-bound invite records. tokenHash is sha256(token) as lowercase hex.
AGENTPROOF_BETA_INVITES=
# Legacy/local fallback only. Do not use as the only production tenant boundary.
AGENTPROOF_BETA_INVITE_TOKEN=
AGENTPROOF_TENANT_CONTROL_PLANE_ENABLED=false
AGENTPROOF_CONTROL_PLANE_SUPABASE_URL=
AGENTPROOF_CONTROL_PLANE_SUPABASE_SERVICE_ROLE_KEY=
# Optional. Defaults shown here.
AGENTPROOF_ONBOARDING_STATES_TABLE=agentproof_github_onboarding_states
AGENTPROOF_TENANT_REPOSITORY_GRANTS_TABLE=agentproof_tenant_repository_grants
AGENTPROOF_GITHUB_INSTALLATIONS_TABLE=agentproof_github_installations
# Optional dedicated store. If omitted, the control-plane Supabase URL/key are reused.
AGENTPROOF_GITHUB_INSTALLATIONS_SUPABASE_URL=
AGENTPROOF_GITHUB_INSTALLATIONS_SUPABASE_SERVICE_ROLE_KEY=
# Local/demo only; do not set for beta/SaaS operation.
AGENTPROOF_ONBOARDING_ALLOW_MEMORY=false
AGENTPROOF_TENANT_GRANTS_ALLOW_MEMORY=false
AGENTPROOF_GITHUB_INSTALLATIONS_ALLOW_MEMORY=false
# Legacy/local seeded grants only. Durable SaaS grants should be created via onboarding.
AGENTPROOF_TENANT_REPOSITORY_GRANTS=
# Optional static emergency tombstone list for tenants already in deletion.
# JSON array or comma-separated tenant ids. Server-only; do not use NEXT_PUBLIC_.
AGENTPROOF_TENANT_DELETION_TOMBSTONES=
# Optional durable deletion-state store. If omitted, the control-plane Supabase URL/key are reused.
AGENTPROOF_TENANT_DELETION_STATE_SUPABASE_URL=
AGENTPROOF_TENANT_DELETION_STATE_SUPABASE_SERVICE_ROLE_KEY=
AGENTPROOF_TENANT_DELETION_STATE_TABLE=agentproof_tenant_deletion_state
# Local/demo only; durable SaaS deletion needs a database-backed tenant deletion state.
AGENTPROOF_TENANT_DELETION_STATE_ALLOW_MEMORY=false

# Optional. Moves GitHub App webhook analysis off the request path by enqueueing
# bounded metadata jobs before GitHub token/evidence fetch. The queue library has
# worker state primitives, bounded run endpoints, and an optional Vercel Cron route.
AGENTPROOF_ANALYSIS_JOB_QUEUE_ENABLED=false
AGENTPROOF_ANALYSIS_JOBS_SUPABASE_URL=
AGENTPROOF_ANALYSIS_JOBS_SUPABASE_SERVICE_ROLE_KEY=
AGENTPROOF_ANALYSIS_JOBS_TABLE=agentproof_analysis_jobs
# Optional. Protects operator diagnostics, queue run endpoints, and summary Slack queue alerts.
AGENTPROOF_OPS_TOKEN=
# Optional. Protects Vercel-compatible cron routes such as /api/cron/analysis-jobs/run
# and /api/cron/reports/cleanup. Vercel Cron can use CRON_SECRET; AGENTPROOF_CRON_TOKEN
# is accepted for non-Vercel schedulers or local smoke tests.
CRON_SECRET=
AGENTPROOF_CRON_TOKEN=
# Optional. Defaults to one job and is still hard-capped by the worker at five.
AGENTPROOF_CRON_ANALYSIS_JOB_BATCH_LIMIT=1
# Local/demo only; do not set for beta/SaaS operation.
AGENTPROOF_ANALYSIS_JOBS_ALLOW_MEMORY=false

# Optional smoke-test target. Defaults to the production alias.
# Webhook smoke secret should match the deployed GITHUB_WEBHOOK_SECRET.
AGENTPROOF_BASE_URL=https://agentproof-pearl.vercel.app
AGENTPROOF_WEBHOOK_SMOKE_SECRET=
# Optional controlled live GitHub App automation smoke. Keep disabled unless you
# intentionally validate analysis-only automation on a maintainer-owned test PR.
AGENTPROOF_ALLOW_LIVE_WEBHOOK_AUTOMATION=0
AGENTPROOF_WEBHOOK_LIVE_PR_URL=
AGENTPROOF_WEBHOOK_LIVE_INSTALLATION_ID=
AGENTPROOF_WEBHOOK_LIVE_ACTION=synchronize
AGENTPROOF_WEBHOOK_LIVE_GITHUB_TOKEN=
AGENTPROOF_WEBHOOK_LIVE_ALLOW_SAVE_REPORTS=0

# Optional live GitHub comment smoke. Keep unset unless you intentionally want to post/update
# an AgentProof marker comment on the target PR.
AGENTPROOF_SMOKE_BASE_URL=https://agentproof-pearl.vercel.app
AGENTPROOF_COMMENT_SMOKE_PR_URL=
AGENTPROOF_COMMENT_SMOKE_GITHUB_TOKEN=
# Optional, only for private PR analysis. Do not reuse broader tokens unless needed.
AGENTPROOF_COMMENT_SMOKE_ANALYZE_TOKEN=
AGENTPROOF_COMMENT_SMOKE_TASK_TEXT=
